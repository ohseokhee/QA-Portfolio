{
  "info": {
    "name": "Day56 JSONPlaceholder API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET 전체 게시글 목록",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/posts",
          "host": ["{{base_url}}"],
          "path": ["posts"]
        }
      }
    },
    {
      "name": "GET 단일 게시글 조회",
      "request": {
        "method": "GET",
        "url": {
          "raw": "{{base_url}}/posts/{{post_id}}",
          "host": ["{{base_url}}"],
          "path": ["posts", "{{post_id}}"]
        }
      }
    },
    {
      "name": "POST 게시글 생성",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"title\": \"QA Portfolio Day56\",\n  \"body\": \"Postman 기초 실습\",\n  \"userId\": 1\n}"
        },
        "url": {
          "raw": "{{base_url}}/posts",
          "host": ["{{base_url}}"],
          "path": ["posts"]
        }
      }
    },
    {
      "name": "PUT 게시글 수정",
      "request": {
        "method": "PUT",
        "header": [
          { "key": "Content-Type", "value": "application/json" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"id\": {{post_id}},\n  \"title\": \"QA Portfolio Day56 수정\",\n  \"body\": \"환경변수 활용 수정 요청\",\n  \"userId\": 1\n}"
        },
        "url": {
          "raw": "{{base_url}}/posts/{{post_id}}",
          "host": ["{{base_url}}"],
          "path": ["posts", "{{post_id}}"]
        }
      }
    },
    {
      "name": "DELETE 게시글 삭제",
      "request": {
        "method": "DELETE",
        "url": {
          "raw": "{{base_url}}/posts/{{post_id}}",
          "host": ["{{base_url}}"],
          "path": ["posts", "{{post_id}}"]
        }
      }
    }
  ]
}
